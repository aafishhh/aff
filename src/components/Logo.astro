---
import { SITE } from 'astrowind:config';

const currentPath = new URL(Astro.url).pathname;

// Language-aware logo text and home URL
const langMap: Record<string, { text: string; home: string }> = {
  '/fr': { text: 'Code Promo TrendTrack', home: '/fr/' },
  '/pl': { text: 'Kod Rabatowy TrendTrack', home: '/pl/' },
  '/es': { text: 'Cupón TrendTrack', home: '/es/' },
};

const langKey = Object.keys(langMap).find((prefix) => currentPath.startsWith(prefix));
const { text: logoText, home: homeUrl } = langKey ? langMap[langKey] : { text: 'TrendTrack Promo Code', home: '/' };
---

<a href={homeUrl} class="flex items-center -ml-0">
  <img
    src="/sitelogo.png"
    alt={logoText}
    class="h-8 w-8 object-cover rounded-md"
  />
  <span class="ml-2 text-2xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white">
    {logoText}
  </span>
</a>
