<PageLayout metadata={metadata} headerData={headerDataPL} footerData={footerDataPL}>

<!-- Kod Rabatowy (Hero Widget) ******************* -->

<section id="promo-code">
<Hero>
  <Fragment slot="title">
    <span class="block mb-4">Kod Rabatowy TrendTrack</span>
    <span class="block text-4xl md:text-6xl font-bold">
      <span
        class="inline-block px-3 py-1 rounded-sm"
        style="background-color: #9FE870; color: #163300;"
      >
        WINNING
      </span>
      - 20% rabatu
    </span>
  </Fragment>

<Fragment slot="subtitle">
  Kod Rabatowy TrendTrack: WINNING - Zweryfikowany kod na 20% rabatu w 2026. Uzyskaj dostep do platformy do analizy e-commerce N1 dla Twojego kolejnego sukcesu.
</Fragment>

<Fragment slot="actions">
    <!-- Karta promocyjna -->
    <div class="mt-8 border border-[#9FE870] rounded-[20px] p-8 bg-white dark:bg-gray-800 shadow-geist w-[300px] mx-auto">
      <p class="text-[12px] font-bold text-muted uppercase tracking-widest">Ekskluzywny kod rabatowy</p>

      <!-- WINNING -->
      <h2 class="text-[50px] font-extrabold text-[#163300] my-3 leading-none tracking-tight">WINNING</h2>

      <p class="text-[16px] font-medium text-muted mb-6">20% rabatu na wszystkie plany</p>

      <!-- Przycisk kopiuj -->
      <button
        onclick="navigator.clipboard.writeText('WINNING'); alert('Kod skopiowany!')"
        class="w-full py-2 mb-3 border border-gray-400 dark:border-gray-500 rounded-[8px] text-[16px] font-semibold hover:bg-gray-100 dark:hover:bg-gray-700 hover:border-gray-500 transition cursor-pointer"
      >
        Skopiuj kod WINNING
      </button>

      <!-- Przycisk aktywuj -->
      <a
        href="https://trendtrack.io?fpr=lanetrendtrack"
        target="_blank"
        rel="sponsored noopener noreferrer"
        class="block w-full py-2 bg-[#9FE870] text-[#163300] font-bold text-[16px] text-center rounded-[8px] hover:opacity-90 transition"
      >
        Aktywuj rabat ->
      </a>

      <div class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-gray-700">
              <div class="flex items-center gap-2 text-muted text-[14px]">
                <span>📋</span> 109 skopiowan dzis
              </div>
              <div class="flex items-center border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-1">
                <span class="text-[16px]">👍</span>
                <span class="text-[14px] font-bold text-heading ml-1">88</span>
              </div>
            </div>
          </div>
  </Fragment>
</Hero>
</section>

  <!-- Note Widget ******************* -->

  <Note title="Specjalna oferta:" description="Uzyj aktywnego kodu rabatowego TrendTrack 'WINNING', aby zaoszczedzic 20% dozywotnio na wszystkich planach miesiecznych i rocznych." />

  <!-- Co to jest TrendTrack ******************* -->

  <section id="what-is-trendtrack" class="max-w-[1200px] mx-auto px-4 sm:px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <p class="text-primary font-bold tracking-wide uppercase text-sm text-center">Przeglad</p>
      <h2 class="text-3xl font-bold mt-2 mb-6 text-center text-heading">Co to jest TrendTrack?</h2>
      <div class="prose prose-lg max-w-none dark:prose-invert">
        <p class="text-muted">
          TrendTrack to kompleksowa platforma inteligencji e-commerce zaprojektowana, aby pomóc sprzedawcom online, dropshipperom i agencjom marketingowym zdobyc przewage konkurencyjna. Zalozona jako narzedzie do badania sklepow Shopify, ewoluowala w zintegrowany pakiet analiz, ktory sledzi ponad 12 milionow sklepow internetowych na calym swiecie.
        </p>
        <p class="text-muted">
          Platforma laczy cztery glowne mozliwosci: <strong>inteligencje sklepu</strong> (szacunki przychodow, trendy ruchu, wykrywanie aplikacji), <strong>odkrywanie produktow</strong> (sledzenie bestsellerow, alerty o produktach trendujacych), <strong>analize kreacji reklamowych</strong> (biblioteki reklam Facebook, TikTok i Pinterest) oraz <strong>monitorowanie konkurencji</strong> (analiza lejkow, dekompozycja strategii cenowych). Uzytkownicy otrzymuja okno w czasie rzeczywistym na produkty, ktore sie sprzedaja, reklamy, ktore dzialaja, i struktury odnoszacych sukcesy sklepow.
        </p>
      </div>
    </div>
  </section>

