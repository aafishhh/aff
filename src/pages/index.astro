---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Prices from '~/components/widgets/Pricing.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'TrendTrack Promo Code: WINNING – Get 20% OFF Discount in 2026',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Promo Code (Hero Widget) ******************* -->

<Hero>
  <Fragment slot="title">
    <span class="block mb-4">TrendTrack Promo Code</span>
    <span class="block text-4xl md:text-6xl font-bold">
      <span 
        class="inline-block px-3 py-1 rounded-sm" 
        style="background-color: #9FE870; color: #163300;"
      >
        WINNING
      </span> 
      - 20% Off
    </span>
  </Fragment>

  <Fragment slot="subtitle">
    TrendTrack Promo Code: WINNING – Get a verified 20% OFF Discount in June 2026. Unlock the #1 ecommerce analytics platform for your next million-dollar win.
  </Fragment>

<Fragment slot="actions">
    <!-- 优惠卡片：宽度设置为 w-[300px]，显得更聚焦且大气 -->
    <div class="mt-8 border-2 border-[#9FE870] rounded-2xl p-8 bg-white shadow-xl w-[300px] mx-auto">
      <p class="text-[12px] font-bold text-gray-500 uppercase tracking-widest">Exclusive Promo Code</p>
      
      <!-- WINNING 字体大小设为 50px -->
      <h2 class="text-[50px] font-extrabold text-[#163300] my-3 leading-none tracking-tight">WINNING</h2>
      
      <p class="text-[16px] font-medium text-gray-600 mb-6">20% off all plans</p>
      
      <!-- 复制按钮 -->
      <button 
        onclick="navigator.clipboard.writeText('WINNING'); alert('Code Copied!')"
        class="w-full py-3 mb-3 border border-gray-400 rounded-lg text-[18px] font-semibold hover:bg-gray-50 transition cursor-pointer"
      >
        Copy code WINNING
      </button>

      <!-- 激活折扣按钮 -->
      <a 
        href="https://trendtrack.io?fpr=lanetrendtrack" 
        target="_blank"
        class="block w-full py-4 bg-[#9FE870] text-[#163300] font-bold text-[18px] text-center rounded-lg hover:opacity-90 transition"
      >
        Activate discount →
      </a>

      <div class="flex items-center justify-between pt-6 border-t border-gray-100">
              <div class="flex items-center gap-2 text-gray-600 text-[14px]">
                <span>📋</span> 127 copies today
              </div>
              <div class="flex flex-col items-center border border-gray-200 rounded-lg px-3 py-1">
                <span class="text-[16px]">👍</span>
                <span class="text-[14px] font-bold text-gray-700">78</span>
              </div>
            </div>
          </div>
  </Fragment>
</Hero>

  <!-- Note Widget ******************* -->

  <Note title="Special Offer:" description="Save 20% lifetime on all monthly and annual plans using our active TrendTrack Promo Code 'WINNING'." />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="TrendTrack Features"
    title="Why Use a TrendTrack Promo Code to Upgrade?"
    subtitle="TrendTrack is the ultimate intelligence suite for e-commerce stores, dropshippers, and ad agencies. Discover what you can unlock at a discount with our exclusive coupon."
    items={[
      {
        title: 'Competitor Store Intelligence',
        description:
          'Monitor Shopify stores, detect theme files, inspect installed applications, and uncover daily sales trends using the TrendTrack Promo Code to save on monthly costs.',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: 'Ad Library Spy Tool',
        description:
          'Scan competitor Meta and TikTok ad campaigns, creative assets, copy, and performance histories easily. Unlock these premium views with a valid TrendTrack Promo Code.',
        icon: 'tabler:components',
      },
      {
        title: 'Trending Product Discovery',
        description:
          'Quickly locate best-selling dropshipping items and trending Shopify products. Upgrade your store research capability using our TrendTrack Promo Code.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Free Chrome Extension Analytics',
        description:
          'Install the free store inspector extension for on-page theme detection, and scale up to professional features at 20% off via a TrendTrack Promo Code.',
        icon: 'tabler:rocket',
      },
