        name: 'Jordan K.',
        job: 'Dropshipping Entrepreneur',
        image: {
          src: 'https://images.unsplash.com/photo-1618835962148-cf177563c6c0?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=930&q=80',
          alt: 'Jordan K.',
        },
      },
      {
        testimonial: `The free Chrome extension is amazing for checking app themes, but upgrading to the Pro plan gave us the real competitor revenue signals we needed. Using the TrendTrack Promo Code made the subscription extremely cost-effective for our dropshipping team.`,
        name: 'Sofia R.',
        job: 'E-commerce Brand Owner',
        image: {
          src: 'https://images.unsplash.com/photo-1561406636-b80293969660?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
          alt: 'Sofia R.',
        },
