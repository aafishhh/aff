---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About TrendTrack Promo Code',
  description:
    'Learn more about TrendTrack Promo Code — your trusted source for verified promo codes, SaaS discounts, and online savings tools.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="About TrendTrack Promo Code"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?auto=format&fit=crop&w=2070&q=80',
      alt: 'Online savings and digital marketing concept',
    }}
  >
    <Fragment slot="title">
      Save more online with <br />
      <span class="text-accent dark:text-white">Verified Promo Codes & Deals</span>
    </Fragment>

    <Fragment slot="subtitle">
      TrendTrack Promo Code is built to help users discover verified discount codes, SaaS deals, and marketing tool
      promotions in one place. We focus on accuracy, simplicity, and helping users save money while using the best
      digital tools online.
    </Fragment>
  </Hero>

  <!-- Stats Section -->
  <Stats
    title="Why users trust us"
    stats={[
      { title: 'Verified Deals', amount: '100+' },
      { title: 'Updated Weekly', amount: '7D' },
      { title: 'Tools Covered', amount: '50+' },
      { title: 'Savings Focus', amount: '24/7' },
    ]}
  />

  <!-- Core Value Features -->
  <Features3
    title="What we provide"
    subtitle="We focus on curated, high-quality promo codes and digital tool discounts to help users save time and money."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Verified Promo Codes',
        description:
          'We aim to list only active and tested promo codes to reduce user frustration and expired coupon clicks.',
        icon: 'tabler:discount',
      },
      {
        title: 'SaaS & AI Tools Deals',
        description:
          'Discover discounts on popular SaaS tools, AI platforms, and marketing software used by creators and businesses.',
        icon: 'tabler:brand-appstore',
      },
      {
        title: 'SEO & Marketing Focus',
        description:
          'We highlight tools used in SEO, growth marketing, and eCommerce to support creators and online businesses.',
        icon: 'tabler:trending-up',
      },
    ]}
  />

  <!-- Extended Value Section -->
  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Fast Updates',
        description:
          'We continuously monitor promotions and update listings to ensure relevance and accuracy.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Global Tools Coverage',
        description:
          'We include tools and deals from global SaaS companies used across marketing, design, and productivity.',
        icon: 'tabler:world',
      },
      {
        title: 'User-Focused Design',
        description:
          'Simple navigation helps users quickly find relevant promo codes without unnecessary complexity.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Transparent Content',
        description:
          'We clearly structure deals and information so users understand what they are clicking before visiting external sites.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'No Spam Policy',
        description:
          'We avoid low-quality or misleading coupons and focus on trustworthy sources whenever possible.',
        icon: 'tabler:ban',
      },
      {
        title: 'Continuous Improvement',
        description:
          'We regularly refine content structure and UX based on user behavior and SEO insights.',
        icon: 'tabler:adjustments',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1740&q=80',
      alt: 'Digital marketing dashboard and analytics',
    }}
  />

  <!-- Values Section -->
  <Steps2
    title="Our mission & values"
    subtitle="We aim to make online savings simple, transparent, and accessible for everyone using digital tools."
    items={[
      {
        title: 'User First',
        description:
          'We prioritize clarity and usefulness over cluttered affiliate-heavy listings.',
      },
      {
        title: 'Accuracy Matters',
        description:
          'We strive to keep promo codes relevant, tested, and up to date.',
      },
      {
        title: 'Transparency',
        description:
          'We clearly structure information so users know what they are clicking and why.',
      },
    ]}
  />

  <!-- Growth & Impact -->
  <Steps2
    title="What we are building"
    subtitle="TrendTrack Promo Code is evolving into a hub for SaaS deals, marketing tools, and digital growth resources."
    isReversed={true}
    callToAction={{
      text: 'Explore Deals',
      href: '/',
    }}
    items={[
      {
        title: 'Global SaaS coverage',
        description:
          'Expanding coverage across AI tools, marketing platforms, and productivity software.',
        icon: 'tabler:world-search',
      },
      {
        title: 'Creator economy focus',
        description:
          'Helping creators and marketers find tools that improve content, traffic, and monetization.',
        icon: 'tabler:users',
      },
      {
        title: 'SEO-driven discovery',
        description:
          'Built with search-first structure to help users find deals through Google and organic traffic.',
        icon: 'tabler:search',
      },
    ]}
  />

  <!-- Coverage -->
  <Features2
    title="Categories we cover"
    tagline="Explore"
    columns={4}
    items={[
      {
        title: 'AI Tools',
        description: 'Discounts on AI writing, image, and productivity tools.',
      },
      {
        title: 'SEO Software',
        description: 'Tools for keyword research, tracking, and optimization.',
      },
      {
        title: 'Marketing SaaS',
        description: 'Platforms for ads, funnels, and automation.',
      },
      {
        title: 'E-commerce Tools',
        description: 'Solutions for Shopify, Amazon, and online stores.',
      },
    ]}
  />

  <!-- Contact -->
  <Features2
    title="Get in touch"
    tagline="Support"
    columns={2}
    items={[
      {
        title: 'Email Support',
        description:
          'For questions about listings, partnerships, or corrections, contact us via email.',
        icon: 'tabler:mail',
      },
      {
        title: 'Partnerships',
        description:
          'We collaborate with SaaS companies and tool providers for promotions and deals.',
        icon: 'tabler:handshake',
      },
    ]}
  />
</Layout>
