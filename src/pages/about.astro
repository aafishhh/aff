---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About us',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About TrendTrack Promo Code"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?auto=format&fit=crop&w=2070&q=80',
      alt: 'TrendTrack Promo Code savings and deals',
    }}
  >
    <Fragment slot="title">
      Helping you save more with verified <br />
      <span class="text-accent dark:text-white">Promo Codes & Exclusive Deals</span>
    </Fragment>

    <Fragment slot="subtitle">
      TrendTrack Promo Code is a deal discovery platform that helps users find the latest discounts, coupon codes,
      and promotional offers across popular SaaS tools and online services. Our goal is simple — make online tools
      more affordable and accessible for everyone by collecting and organizing the best available deals in one place.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Our platform impact"
    stats={[
      { title: 'Deal Updates', amount: 'Daily' },
      { title: 'Supported Tools', amount: '50+' },
      { title: 'Active Coupons', amount: '100+' },
      { title: 'User Focus', amount: 'Global' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="What we offer"
    subtitle="We focus on delivering high-quality, easy-to-use deal discovery experiences for users looking to save money on digital tools and subscriptions."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Verified Promo Codes',
        description:
          'We collect and organize working promo codes and discount offers to help users avoid expired or invalid deals.',
        icon: 'tabler:discount',
      },
      {
        title: 'SaaS Discounts',
        description:
          'Find exclusive savings for popular SaaS tools, marketing platforms, AI tools, and productivity apps.',
        icon: 'tabler:brand-producthunt',
      },
      {
        title: 'Deal Updates',
        description:
          'We continuously update our database to ensure users always get access to the latest available offers.',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Marketing Tools',
        description:
          'Save on SEO, advertising, and growth tools used by marketers and entrepreneurs worldwide.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'AI Tools',
        description:
          'Discover discounts on AI writing, image generation, and automation platforms.',
        icon: 'tabler:robot',
      },
      {
        title: 'Startup Tools',
        description:
          'Get early-stage startup tools at reduced prices for building and scaling faster.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Creator Tools',
        description:
          'Discounts for content creators, designers, and video editors.',
        icon: 'tabler:video',
      },
      {
        title: 'Business Tools',
        description:
          'Save on CRM, analytics, and business management platforms.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'E-commerce Tools',
        description:
          'Find deals for Shopify apps, dropshipping tools, and online store platforms.',
        icon: 'tabler:shopping-cart',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1740&q=80',
      alt: 'Digital tools and analytics dashboard',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Our mission"
    subtitle="We believe software should be affordable and accessible. Our mission is to help users discover better deals and reduce the cost of essential digital tools."
    items={[
      {
        title: 'Find the best deals',
        description:
          'We scan and organize promo codes from multiple sources to surface the most valuable offers.',
      },
      {
        title: 'Save time and money',
        description:
          'Instead of searching across multiple websites, users can find everything in one place.',
      },
      {
        title: 'Improve access to tools',
        description:
          'We help individuals and businesses access tools they need without overpaying.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Why choose TrendTrack"
    subtitle="We focus on reliability, simplicity, and real value for users looking for discounts on digital products."
    isReversed={true}
    callToAction={{
      text: 'Browse deals',
      href: '/',
    }}
    items={[
      {
        title: 'Trusted deal curation',
        description:
          'We prioritize verified and relevant promo codes instead of spam or outdated offers.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Fast updates',
        description:
          'Our listings are regularly updated to reflect the latest promotions.',
        icon: 'tabler:clock',
      },
      {
        title: 'User-first experience',
        description:
          'We design everything with clarity and ease of use in mind.',
        icon: 'tabler:user-heart',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Our focus categories"
    tagline="What we cover"
    columns={4}
    items={[
      {
        title: 'AI Tools',
        description: 'Discounts on AI writing, image, and automation tools.',
      },
      {
        title: 'Marketing Software',
        description: 'SEO, ads, analytics, and growth platforms.',
      },
      {
        title: 'Creator Tools',
        description: 'Design, video editing, and content creation tools.',
      },
      {
        title: 'Business SaaS',
        description: 'CRM, productivity, and management tools.',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Contact & Support"
    tagline="Get in touch"
    columns={2}
    items={[
      {
        title: 'Email support',
        description:
          'For partnership, corrections, or promo code submissions, contact our team anytime.',
        icon: 'tabler:mail',
      },
      {
        title: 'Submit a deal',
        description:
          'Found a working coupon or deal? Share it with us and help the community save more.',
        icon: 'tabler:gift',
      },
    ]}
  />
</Layout>
