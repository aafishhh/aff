---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Comparison from '~/components/widgets/Comparison.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Alternatives - TrendTrack Promo Code Comparison',
  description: 'Compare TrendTrack with other promo code solutions. See why TrendTrack is the best choice for your business.',
};

const competitors = [
  {
    name: 'TrendTrack',
    yourProduct: true,
    features: {
      'Promo Code Generation': true,
      'Real-time Analytics': true,
      'Unlimited Campaigns': true,
      'API Access': true,
      'Team Collaboration': true,
      'Custom Branding': true,
      'Advanced Reporting': true,
      'Priority Support': true,
      'Price': '$99/month',
    },
  },
  {
    name: 'Competitor A',
    features: {
      'Promo Code Generation': true,
      'Real-time Analytics': false,
      'Unlimited Campaigns': false,
      'API Access': false,
      'Team Collaboration': true,
      'Custom Branding': false,
      'Advanced Reporting': false,
      'Priority Support': false,
      'Price': '$149/month',
    },
  },
  {
    name: 'Competitor B',
    features: {
      'Promo Code Generation': true,
      'Real-time Analytics': true,
      'Unlimited Campaigns': true,
      'API Access': false,
      'Team Collaboration': false,
      'Custom Branding': true,
      'Advanced Reporting': false,
      'Priority Support': false,
      'Price': '$199/month',
    },
  },
  {
    name: 'Competitor C',
    features: {
      'Promo Code Generation': true,
      'Real-time Analytics': true,
      'Unlimited Campaigns': false,
      'API Access': true,
      'Team Collaboration': true,
      'Custom Branding': true,
      'Advanced Reporting': true,
      'Priority Support': false,
      'Price': '$249/month',
    },
  },
];
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <Hero
    tagline="Alternatives"
    title="Why Choose TrendTrack?"
    subtitle="Compare TrendTrack with other promo code management solutions. See why industry leaders trust us for their promotional campaigns."
    actions={[
      {
        variant: 'primary',
        text: 'Get Started Free',
        href: '#comparison',
        icon: 'tabler:check',
      },
    ]}
  >
    <Fragment slot="image">
      <div class="flex justify-center">
        <svg class="w-full max-w-md" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
          <rect width="400" height="300" fill="#f3f4f6" rx="8" />
          <circle cx="100" cy="80" r="30" fill="#3b82f6" opacity="0.8" />
          <circle cx="300" cy="100" r="25" fill="#10b981" opacity="0.8" />
          <circle cx="150" cy="200" r="35" fill="#f59e0b" opacity="0.8" />
          <circle cx="280" cy="220" r="28" fill="#8b5cf6" opacity="0.8" />
          <line x1="100" y1="80" x2="300" y2="100" stroke="#bfdbfe" stroke-width="2" />
          <line x1="100" y1="80" x2="150" y2="200" stroke="#bfdbfe" stroke-width="2" />
          <line x1="300" y1="100" x2="280" y2="220" stroke="#bfdbfe" stroke-width="2" />
        </svg>
      </div>
    </Fragment>
  </Hero>

  <!-- Key Advantages Widget ******* -->
  <Content
    tagline="Our Advantages"
    title="What Sets TrendTrack Apart"
    items={[
      {
        title: '20% More Affordable',
        description: 'Get premium features at the best price in the market. No hidden fees, transparent pricing.',
      },
      {
        title: 'Superior Analytics',
        description: 'Real-time tracking and detailed insights into campaign performance and customer behavior.',
      },
      {
        title: 'Unlimited Flexibility',
        description: 'Run unlimited campaigns with no restrictions. Scale your promotions as your business grows.',
      },
      {
        title: 'Full API Access',
        description: 'Integrate seamlessly with your existing systems. Complete API documentation and support.',
      },
      {
        title: 'Team Collaboration',
        description: 'Work together efficiently with role-based permissions and activity tracking.',
      },
      {
        title: '24/7 Priority Support',
        description: 'Dedicated support team ready to help you succeed. Average response time under 2 hours.',
      },
    ]}
    columns={3}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Comparison Table Widget ***** -->
  <div id="comparison" class="relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="mb-12">
        <h2 class="text-4xl lg:text-5xl font-bold mb-4 text-center">Feature Comparison</h2>
        <p class="text-xl text-muted text-center max-w-3xl mx-auto">
          Detailed comparison of features, pricing, and support across leading promo code platforms.
        </p>
      </div>

      <!-- Table for desktop -->
      <div class="hidden md:block overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
              <th class="px-6 py-4 text-left font-bold">Features</th>
              {competitors.map((competitor) => (
                <th
                  class={`px-6 py-4 text-center font-bold ${
                    competitor.yourProduct ? 'bg-blue-50 dark:bg-blue-900/20' : ''
                  }`}
                >
                  <div class="flex flex-col items-center gap-2">
                    <span>{competitor.name}</span>
                    {competitor.yourProduct && (
                      <span class="inline-block px-2 py-1 bg-blue-500 text-white text-xs rounded-full">
                        You are here
                      </span>
                    )}
                  </div>
                </th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            {Object.keys(competitors[0].features).map((feature) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                <td class="px-6 py-4 font-semibold">{feature}</td>
                {competitors.map((competitor) => (
                  <td
                    class={`px-6 py-4 text-center ${
                      competitor.yourProduct ? 'bg-blue-50 dark:bg-blue-900/20' : ''
                    }`}
                  >
                    {typeof competitor.features[feature as keyof typeof competitor.features] === 'boolean' ? (
                      competitor.features[feature as keyof typeof competitor.features] ? (
                        <svg class="w-6 h-6 mx-auto text-green-500" fill="currentColor" viewBox="0 0 20 20">
                          <path
                            fill-rule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clip-rule="evenodd"
                          ></path>
                        </svg>
                      ) : (
                        <svg class="w-6 h-6 mx-auto text-gray-300 dark:text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                          <path
                            fill-rule="evenodd"
                            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                            clip-rule="evenodd"
                          ></path>
                        </svg>
                      )
                    ) : (
                      <span class={competitor.yourProduct ? 'font-bold text-blue-600 dark:text-blue-400' : ''}>
                        {competitor.features[feature as keyof typeof competitor.features]}
                      </span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Cards for mobile -->
      <div class="md:hidden space-y-6">
        {competitors.map((competitor) => (
          <div class={`rounded-lg border-2 p-6 ${competitor.yourProduct ? 'border-blue-500 bg-blue-50 dark:bg-blue-900/20' : 'border-gray-200 dark:border-gray-700'}`}>
            <h3 class="text-xl font-bold mb-4">
              {competitor.name}
              {competitor.yourProduct && <span class="ml-2 text-sm bg-blue-500 text-white px-2 py-1 rounded">Recommended</span>}
            </h3>
            <ul class="space-y-3">
              {Object.entries(competitor.features).map(([feature, value]) => (
                <li class="flex items-center justify-between">
                  <span class="text-sm">{feature}</span>
                  {typeof value === 'boolean' ? (
                    value ? (
                      <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                        <path
                          fill-rule="evenodd"
                          d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                          clip-rule="evenodd"
                        ></path>
                      </svg>
                    ) : (
                      <svg class="w-5 h-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                        <path
                          fill-rule="evenodd"
                          d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                          clip-rule="evenodd"
                        ></path>
                      </svg>
                    )
                  ) : (
                    <span class="font-semibold text-blue-600 dark:text-blue-400">{value}</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Customer Stories Widget **** -->
  <Content
    isReversed
    isAfterContent
    tagline="Trusted by Industry Leaders"
    title="Why Customers Switch to TrendTrack"
    items={[
      {
        title: 'E-commerce Giant Increases Sales by 40%',
        description:
          'By switching to TrendTrack, a leading e-commerce platform reduced campaign setup time from 2 hours to 15 minutes.',
      },
      {
        title: 'SaaS Company Saves $50K Annually',
        description:
          'TrendTrack\'s competitive pricing and unlimited campaigns resulted in significant cost savings for a growing SaaS business.',
      },
      {
        title: 'Agency Manages 200+ Campaigns',
        description:
          'With TrendTrack\'s API and team collaboration features, a digital agency scaled from managing 50 to 200 campaigns monthly.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CTA Widget ******************** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Free Trial',
        href: '#',
        icon: 'tabler:check',
      },
      {
        variant: 'secondary',
        text: 'Schedule Demo',
        href: '#',
      },
    ]}
  >
    <Fragment slot="title">Ready to switch to TrendTrack?</Fragment>

    <Fragment slot="subtitle">
      Join thousands of businesses that have already made the switch. No credit card required for the free trial.
    </Fragment>
  </CallToAction>
</Layout>
